# API keys — copy this file to .env and fill in your own values.
# .env is gitignored and will never be committed.
#
# eBird Status & Trends key:  https://ebird.org/st/request
# eBird API key:              https://ebird.org/api/keygen

EBIRDST_KEY=YOUR_EBIRDST_KEY_HERE
EBIRD_API_KEY=YOUR_EBIRD_API_KEY_HERE
USER=Your Name
